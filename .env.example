# Telegram Bot Configuration
# 1. Message @BotFather on Telegram -> /newbot -> copy the token here
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 2. Message your bot, then visit https://api.telegram.org/bot<TOKEN>/getUpdates
#    Find "chat":{"id": XXXXXXX} in the response and paste the ID here
TELEGRAM_CHAT_ID=your_chat_id_here

# Rate-X scraper configuration (optional)
# Backend endpoint used by ratex_scraper.py
RATEX_API_URL=https://api.rate-x.io
# Request timeout in seconds
RATEX_TIMEOUT=25
